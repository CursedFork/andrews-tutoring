# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# ================================================================

# ------ Web3Forms (contact form) -------------------------------
# Free tier: 250 submissions/month  |  https://web3forms.com
# Steps:
#   1. Go to web3forms.com and enter your email to get an access key
#   2. Paste the access key below
# NOTE: Without this value the Submit button is disabled.
VITE_WEB3FORMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------ Calendly (optional) ------------------------------------
# Get embed URL: Calendly Dashboard > Share > Embed > Inline Widget
# Paste your personal Calendly link below
VITE_CALENDLY_URL=https://calendly.com/your-username
