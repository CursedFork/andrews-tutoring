# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# ================================================================

# ------ Formspree (contact form) -------------------------------
# Free tier: 50 submissions/month  |  https://formspree.io
# Steps:
#   1. Create account at formspree.io
#   2. Click "New Form", give it a name, and set your email
#   3. Copy the endpoint URL shown after creation
#   4. Paste it below
# NOTE: Without this value the Submit button is disabled.
VITE_FORMSPREE_URL=https://formspree.io/f/xxxxxxxx

# ------ Calendly (optional) ------------------------------------
# Get embed URL: Calendly Dashboard > Share > Embed > Inline Widget
# Paste your personal Calendly link below
VITE_CALENDLY_URL=https://calendly.com/your-username
