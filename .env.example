# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# ================================================================

# ------ EmailJS ------------------------------------------------
# Free tier: 200 emails/month  |  https://www.emailjs.com
# Steps:
#   1. Create account at emailjs.com
#   2. Add an Email Service (connect your Gmail)
#   3. Create a Template — use these variable names:
#        {{from_name}}  {{from_email}}  {{phone}}
#        {{subject}}    {{message}}
#   4. Paste your IDs below
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ------ Calendly (optional) ------------------------------------
# Get embed URL: Calendly Dashboard > Share > Embed > Inline Widget
# Paste your personal Calendly link below
VITE_CALENDLY_URL=https://calendly.com/your-username
